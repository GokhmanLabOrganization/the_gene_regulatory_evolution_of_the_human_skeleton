# merge kept reads and remapped kept reads
rule merge:
    input:
        f1=res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.remap.kept.sort.bam',
        f2=res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.keep.sort.bam'
    output:
        res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.remap.kept.merged.bam'
    params:
        job_out_dir  = jobs_output_dir,
        job_out_file = "merge_{species}_{sample}",
        job_name     = "merge_{species}_{sample}",
        run_time     = "4:59",
        cores        = "16",
        memory       = "80",
    shell:
        "samtools merge {output} {input.f1} {input.f2}"


# index merged bam
