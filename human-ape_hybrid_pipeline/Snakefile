    params:
        job_out_dir  = jobs_output_dir,
        job_out_file = "sort1_{species}_{sample}",
        job_name     = "sort1_{species}_{sample}",
        run_time     = "3:59",
        cores        = "16",
        memory       = "20",
    shell: "samtools sort {input} -o {output}"

rule index_star_bam:
    input:
        res_outputs_dir + '/STAR2/{species}/{sample}/Aligned.out.sort.bam'
    output:
        res_outputs_dir + '/STAR2/{species}/{sample}/Aligned.out.sort.bam.bai'
    params:
        job_out_dir  = jobs_output_dir,
        job_out_file = "indexS2_{species}_{sample}",
        job_name     = "indexS2_{species}_{sample}",
        run_time     = "2:59",
        cores        = "12",
        memory       = "20",
    conda:
        config['conda']
    shell:
        "samtools index {input}"

rule rmdup:
    input:
        bam = res_outputs_dir + '/STAR2/{species}/{sample}/Aligned.out.sort.bam',
        bai = res_outputs_dir + '/STAR2/{species}/{sample}/Aligned.out.sort.bam.bai',
    output:
        res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.bam',
    params:
        job_out_dir  = jobs_output_dir,
        job_out_file = 'rmdup_{species}_{sample}',
        job_name     = 'rmdup_{species}_{sample}',
        has_umi      = lambda wildcards: sample2UMI[wildcards.sample],
        run_time     = "05:59",
        cores        = "12",
        memory       = "80",
    log:
        jobs_output_dir + '/rmdups_{species}_{sample}.log',
    conda:
        config['conda']
    shell:
        r"""
        if [ "{params.has_umi}" = "yes" ]; then
            echo "Running UMI-tools dedup" >> {log}
            umi_tools dedup \
                --stdin={input.bam} \
                --stdout={output} \
                --log={log} \
                --extract-umi-method=read_id \ 
                --umi-separator=":"
        else
            echo "Running Picard MarkDuplicates" >> {log}
            java -Xms4g -jar picard.jar MarkDuplicates \
                I={input.bam} \
                O={output} \
                M={log} \
                REMOVE_DUPLICATES=true \
                DUPLICATE_SCORING_STRATEGY=RANDOM
        fi
        """

# Hornet - correct allele mapping biases
#identifies reads that may have mapping biases
#hornet - https://github.com/TheFraserLab/hornet
#WASP - https://github.com/bmvdgeijn/WASP
#Note: Reads that overlap indels are currently excluded and will not be present in any of the 'remap' files
#or the input.keep.bam file. For this reason the total number of reads will not add up to the
#number of reads provided in the input.sort.bam file.

#To make the snps.txt.gz files, from vcf files separated by chromosome:
#mkdir snps
#for i in chr*.vcf.gz; do j=$(echo $i | sed 's/\..*//'); pigz -dc $i | grep -v "^#" | awk '{if ((length($4) == 1) && (length($5) == 1)) printf ("%s\t%s\t%s\n", $2, $4, $5)}' | pigz > ${j}.snps.txt.gz; done
#From a single vcf:
#pigz -dc data.vcf.gz | grep -v "^#" | awk '{if ((length($4) == 1) && (length($5) == 1)) printf ("%s\t%s\t%s\n", $2, $4, $5) | "pigz > "$1".snps.txt.gz"}'

rule Hornet_find_snps:
    input:
        bam=res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.bam',
    output:
        R1=res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.remap.fq1.gz',
        R2=res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.remap.fq2.gz',
        keep=res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.keep.bam',
        toremap=res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.to.remap.bam',
        #dropped=f'{res_outputs_dir}/Hornet/{species}/{{sample}}/rmdup.dropped.bam',
    params:
        seq_type = lambda wildcards: sample2seq_type[wildcards.sample],
        snps_path = lambda wildcards: config["species"][wildcards.species]["snps_wasp"],
        res_out_dir = res_outputs_dir,
        job_out_dir  = jobs_output_dir,
        job_out_file = "findSNPs_{species}_{sample}",
        job_name     = "findsnps_{species}_{sample}",
        run_time     = "11:59",
        cores        = "16",
        memory       = "80",
        p_flag = lambda wildcards: "-p" if sample2seq_type[wildcards.sample] == "paired-end" else ""
    shell: """
        if [ "{params.seq_type}" = "paired-end" ]; then
            python snakemake-scripts/Hornet/mapping/find_intersecting_snps_for_single.py \
                {params.p_flag} \
                {input.bam} \
                {params.snps_path};
        else
            touch {output.R2};
            python snakemake-scripts/Hornet/mapping/find_intersecting_snps_for_single.py \
                {input.bam} \
                {params.snps_path};
            mv {params.res_out_dir}/Hornet/{wildcards.species}/{wildcards.sample}/rmdup.remap.fq.gz {output.R1};
        fi
    """

rule Hornet_remap:
    input:
        unpack(get_sample_raw_read_paths_2remap),
        unpack(ret_sj_files_sy_species),
        genome=res_outputs_dir + '/STAR/{species}/Genome',
        sj=res_outputs_dir + '/STAR1/{species}/{sample}/SJ.out.tab', 
    output:
        res_outputs_dir + '/Hornet/{species}/{sample}/remapped_Aligned.out.bam'
    params:
        seq_type = lambda wildcards: sample2seq_type[wildcards.sample],
        sj_files_str = lambda wildcards: sj_files_str_by_species[wildcards.species],
        res_out_dir = res_outputs_dir,
        job_out_dir  = jobs_output_dir,
        job_out_file = "remap_{species}_{sample}",
        job_name     = "remap_{species}_{sample}",
        run_time     = "04:59",
        cores        = "16",
        memory       = "80",
    threads: 16
    shell: """
        if [ "{params.seq_type}" = "paired-end" ]; then
            STAR \
                --genomeDir {params.res_out_dir}/STAR/{wildcards.species} \
                --outFileNamePrefix {params.res_out_dir}/Hornet/{wildcards.species}/{wildcards.sample}/remapped_ \
                --outSAMattributes MD NH \
                --outSAMtype BAM Unsorted \
                --runThreadN {threads} \
                --readFilesCommand zcat \
                --outFilterMultimapNmax 1 \
                --sjdbFileChrStartEnd {params.sj_files_str} \
                --readFilesIn {input.R1} {input.R2} \
                --limitSjdbInsertNsj 9000000 \
                --limitGenomeGenerateRAM 250000000000;
        else
            STAR \
                --genomeDir {params.res_out_dir}/STAR/{wildcards.species} \
                --outFileNamePrefix {params.res_out_dir}/Hornet/{wildcards.species}/{wildcards.sample}/remapped_ \
                --outSAMattributes MD NH \
                --outSAMtype BAM Unsorted \
                --runThreadN {threads} \
                --readFilesCommand zcat \
                --outFilterMultimapNmax 1 \
                --sjdbFileChrStartEnd {params.sj_files_str} \
                --readFilesIn {input.R1} \
                --limitSjdbInsertNsj 9000000 \
                --limitGenomeGenerateRAM 250000000000;
        fi
    """

# sort remapped bams
rule sort_remappedReads:
    input:
        res_outputs_dir + '/Hornet/{species}/{sample}/remapped_Aligned.out.bam'
    output:
        res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.remap.sort.bam'
    params:
        job_out_dir  = jobs_output_dir,
        job_out_file = "sortRemapped_{species}_{sample}",
        job_name     = "sortR_{species}_{sample}",
        run_time     = "3:59",
        cores        = "16",
        memory       = "80",
    threads: 12
    shell: "samtools sort -n {input} -o {output}"

# filter remapped reads
rule Hornet_filter:
    input:
        toremap=res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.to.remap.bam',
        remapped=res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.remap.sort.bam',
    output:
        kept=res_outputs_dir + '/Hornet/{species}/{sample}/rmdup.remap.kept.bam'
    params:
        p_flag = lambda wildcards: '-p' if sample2seq_type[wildcards.sample] == 'paired-end' else '',
        seq_type = lambda wildcards: sample2seq_type[wildcards.sample],
        job_out_dir  = jobs_output_dir,
        job_out_file = "HornetFilter_{species}_{sample}",
        job_name     = "HFilter_{species}_{sample}",
        run_time     = "7:59",
        cores        = "16",
        memory       = "80",
    threads: 16
    shell:
        """
        if [ "{params.seq_type}" = "paired-end" ]; then
            python snakemake-scripts/Hornet/mapping/filter_remapped_reads.py -p {input.toremap} {input.remapped} {output.kept}
        else
            python snakemake-scripts/Hornet/mapping/filter_remapped_reads.py {input.toremap} {input.remapped} {output.kept}
        fi
        """

