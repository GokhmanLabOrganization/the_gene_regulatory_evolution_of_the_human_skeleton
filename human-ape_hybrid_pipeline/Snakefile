import os
import pandas as pd

##########################################################################################
# creating output directories and loading config variables
##########################################################################################

jobs_output_dir = config['paths']['output'] + '/job_outputs'
res_outputs_dir = config['paths']['output'] + '/outputs'

if not os.path.exists(jobs_output_dir):
	print("Creating jobs output directory: %s" % (jobs_output_dir) )
	os.makedirs(jobs_output_dir)

if not os.path.exists(res_outputs_dir):
	print("Creating output directory: %s" % (res_outputs_dir) )
	os.makedirs(res_outputs_dir)

##########################################################################################
# functions
##########################################################################################

#extract a column from a table, and return the table too
def get_samples_metadata(samples_table_path, samples_colname):
    samples_data = pd.read_csv(samples_table_path, sep='\t');
    samples_data.set_index(samples_colname, inplace=True, drop=False); #add indices to the list (starts with 0)
    return(samples_data[samples_colname].tolist(), samples_data)

#return a list of samples2attributes
def map_samples2attributes(samples_df, colname1, colname2):
    return({str(row[colname1]) : str(row[colname2]) for index, row in samples_df.iterrows()})

def get_sample_raw_read_paths(wildcards):
	if sample2seq_type[wildcards.sample] == 'paired-end':
		return( { 'R1' : sample2path1[wildcards.sample],
				'R2' : sample2path2[wildcards.sample]})
	else: # assuming 'single-end'
		return( { 'R1' : sample2path1[wildcards.sample]})

def sj_output(species):
    """Return all SJ.out.tab files for a given species."""
    indices = [i for i, value in enumerate(SAMPLES_DF['species']) if value == species]
    return [
        res_outputs_dir + '/STAR1/' + SPECIES[i] + '/' + SAMPLES[i] + '/SJ.out.tab'
        for i in indices
    ]

def get_sample_raw_read_paths_trimmed(wildcards):
    if sample2seq_type[wildcards.sample] == 'paired-end':
        return( { 'R1': res_outputs_dir + '/seqprep/' + wildcards.sample + '/r1_trimmed.fastq.gz',
                'R2': res_outputs_dir + '/seqprep/' + wildcards.sample + '/r2_trimmed.fastq.gz'})
    else: # assuming 'single-end'
        return({'R1': res_outputs_dir + '/seqprep/' + wildcards.sample + '/r1_trimmed.fastq.gz'})


def get_sample_raw_read_paths_2remap(wildcards):
    if sample2seq_type[wildcards.sample] == 'paired-end':
        return( { 'R1': res_outputs_dir + '/Hornet/' + wildcards.species + '/' + wildcards.sample + '/rmdup.remap.fq1.gz',
                'R2': res_outputs_dir + '/Hornet/' + wildcards.species + '/' + wildcards.sample + '/rmdup.remap.fq2.gz'})
    else: # assuming 'single-end'
        return({'R1': res_outputs_dir + '/Hornet/' + wildcards.species + '/' + wildcards.sample + '/rmdup.remap.fq1.gz'})


def ret_sj_files_sy_species(wildcards):
    return sj_files_by_species[wildcards.species]


##########################################################################################
# constants
##########################################################################################

samples_filename = config['paths']['samples_metadata']
SAMPLES, SAMPLES_DF = get_samples_metadata(samples_filename, 'sample_id')
SPECIES = SAMPLES_DF['species'].tolist()

#create dictionaries (extract SAMPLES:attributes)
sample2path1 = map_samples2attributes(SAMPLES_DF,'sample_id','read1')
sample2path2 = map_samples2attributes(SAMPLES_DF,'sample_id','read2')
sample2adapter1 = map_samples2attributes(SAMPLES_DF,'sample_id','adapter1')
sample2adapter2 = map_samples2attributes(SAMPLES_DF,'sample_id','adapter2')
sample2seq_type = map_samples2attributes(SAMPLES_DF,'sample_id','seq_type')
sample2dataOrg = map_samples2attributes(SAMPLES_DF,'sample_id','dataOrg')
sample2seqprep = map_samples2attributes(SAMPLES_DF,'sample_id','seqprep')
sample2UMI = map_samples2attributes(SAMPLES_DF,'sample_id','UMI')

sj_files_by_species = {
    sp: sj_output(sp) for sp in SAMPLES_DF['species'].unique()
}

sj_files_str_by_species = {
    sp: ' '.join(files) for sp, files in sj_files_by_species.items()
}

############################################################################################
# rules
############################################################################################

rule all:
    input:
        expand(res_outputs_dir + '/ASE/{species}/{sample}_ase_by_reads_merged.txt',
        zip, 
        sample=SAMPLES,
        species=SPECIES)

# remove adapters
rule seqprep:
	input:
		unpack(get_sample_raw_read_paths),
	output:
		R1 = res_outputs_dir + '/seqprep/{sample}/r1_trimmed.fastq.gz',
		R2 = res_outputs_dir + '/seqprep/{sample}/r2_trimmed.fastq.gz',
		R1d = res_outputs_dir + '/seqprep/{sample}/r1_discard.fastq.gz',
		R2d = res_outputs_dir + '/seqprep/{sample}/r2_discard.fastq.gz'
	params:
		dataOrg = lambda wildcards: sample2dataOrg[wildcards.sample],
		seq_type = lambda wildcards: sample2seq_type[wildcards.sample],
		seq_prep = lambda wildcards: sample2seqprep[wildcards.sample],
        adapter1 = lambda wildcards: sample2adapter1[wildcards.sample],
        adapter2_flag= lambda wildcards: f"-B {sample2adapter2[wildcards.sample]}" if sample2seq_type[wildcards.sample] == "paired-end" else "",
		job_out_dir  = jobs_output_dir,
		job_out_file = "seqprep_{sample}",
		job_name     = "SP_{sample}",
		run_time     = "24:00",
		cores        = "16",	
		memory       = "80",
	run:
		if (params.seq_prep == 'yes'):
			shell("SeqPrep \
						-f {input.R1} -r {input.R2} \
						-1 {output.R1} -2 {output.R2} \
						-3 {output.R1d} -4 {output.R2d} \
					-A {params.adapter1} {params.adapter2_flag}")
		elif (params.seq_type == 'paired-end'):
			shell("cp {input.R1} {output.R1} && cp {input.R2} {output.R2} && touch {output.R1d} && touch {output.R2d}")
		else:
			shell("cp {input.R1} {output.R1} && touch {output.R2} && touch {output.R1d} && touch {output.R2d}")

# create STAR genome indices
rule star_genome:
    input:
        fasta=lambda wildcards: config["species"][wildcards.species]["fasta"],
        gff=lambda wildcards: config["species"][wildcards.species]["gff"],
    threads: 16
    output:
        res_outputs_dir + '/STAR/{species}/Genome'
    params:
        overhang = lambda wildcards: config['star']['overhang'],
        job_out_dir  = jobs_output_dir,
        res_out_dir = res_outputs_dir,
        job_out_file = "star_gen_{species}",
        job_name     = "star_gen_{species}",
        run_time     = "14:59",
        cores        = "16",
        memory       = "20",
    shell:
        """
        STAR \
            --runThreadN {threads} \
            --runMode genomeGenerate \
            --genomeDir {params.res_out_dir}/STAR/{wildcards.species} \
            --genomeFastaFiles {input.fasta} \
            --sjdbGTFfile {input.gff} \
            --sjdbOverhang {params.overhang} \
            --limitGenomeGenerateRAM 90000000000 \
            --outTmpDir {params.res_out_dir}/STAR/{wildcards.species}/tmp_{wildcards.species}
        """

# align reads with STAR
rule star_align:
    input:
        unpack(get_sample_raw_read_paths_trimmed),
        genome = res_outputs_dir + '/STAR/{species}/Genome'
    output:
        bam = res_outputs_dir + '/STAR1/{species}/{sample}/Aligned.out.bam',
        sj  = res_outputs_dir + '/STAR1/{species}/{sample}/SJ.out.tab'
    threads: 16
    params:
        seq_type   = lambda wildcards: sample2seq_type[wildcards.sample],
        res_out_dir = res_outputs_dir,
        reads = lambda wildcards, input: (
            f"{input.R1} {input.R2}"
            if sample2seq_type[wildcards.sample] == "paired-end"
            else f"{input.R1}"
        ),
        job_out_dir  = jobs_output_dir,
        job_out_file = "star1_{species}_{sample}",
        job_name     = "S1_{species}_{sample}",
        run_time     = "9:59",
        cores        = "16",
        memory       = "20"
    shell: """
        STAR \
            --genomeDir {params.res_out_dir}/STAR/{wildcards.species} \
            --outFileNamePrefix {params.res_out_dir}/STAR1/{wildcards.species}/{wildcards.sample}/ \
            --outSAMattributes MD NH \
            --outSAMtype BAM Unsorted \
            --runThreadN {threads} \
            --readFilesCommand zcat \
            --readFilesIn {params.reads} \
            --outFilterMultimapNmax 1 \
            --limitGenomeGenerateRAM 90000000000
    """

# second round of alignment with splice junctions from first round
rule star_align2:
    input:
        unpack(get_sample_raw_read_paths_trimmed),
        sj     = res_outputs_dir + "/STAR1/{species}/{sample}/SJ.out.tab",
        genome = res_outputs_dir + "/STAR/{species}/Genome"
    output:
        bam = res_outputs_dir + "/STAR2/{species}/{sample}/Aligned.out.bam"
    threads: 16
    params:
        seq_type   = lambda wildcards: sample2seq_type[wildcards.sample],
        res_out_dir = res_outputs_dir,
        sj_files_str = lambda wildcards: sj_files_str_by_species[wildcards.species],
        reads = lambda wildcards, input: (
            f"{input.R1} {input.R2}"
            if sample2seq_type[wildcards.sample] == "paired-end"
            else f"{input.R1}"
        ),
        job_out_dir  = jobs_output_dir,
        job_out_file = "star2_{species}_{sample}",
        job_name     = "S2_{species}_{sample}",
        run_time     = "11:59",
        cores        = "16",
        memory       = "40"
    shell: """
        STAR \
            --genomeDir {params.res_out_dir}/STAR/{wildcards.species} \
            --outFileNamePrefix {params.res_out_dir}/STAR2/{wildcards.species}/{wildcards.sample}/ \
            --outSAMattributes MD NH \
            --outSAMtype BAM Unsorted \
            --runThreadN {threads} \
            --readFilesCommand zcat \
            --readFilesIn {params.reads} \
            --outFilterMultimapNmax 1 \
            --sjdbFileChrStartEnd {params.sj_files_str} \
            --limitSjdbInsertNsj 9000000 \
            --limitGenomeGenerateRAM 90000000000
    """

# sort bam files
rule sort:
